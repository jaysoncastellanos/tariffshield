# ══════════════════════════════════════════════════════════════
# TariffShield — Environment Variables
# Copy this to .env for local dev. Set these in Railway for prod.
# ══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Public URL (set after Railway gives you a domain)
APP_URL=https://your-app.up.railway.app

# ── Database ─────────────────────────────────────────────────
# SQLite file path (Railway volume mount)
DATABASE_URL=/app/data/data.db

# ── Security ─────────────────────────────────────────────────
# Random 32-char secret for admin endpoints (agent scan, briefings)
ADMIN_KEY=your-random-admin-secret-here

# ── Stripe ───────────────────────────────────────────────────
# Live keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from https://dashboard.stripe.com/products
# MONITOR plan — $500/mo
STRIPE_PRICE_MONITOR=price_...

# OPTIMIZE plan — $2,500/mo
STRIPE_PRICE_OPTIMIZE=price_...

# ── Perplexity AI ────────────────────────────────────────────
# From https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# ── Email (SMTP) ─────────────────────────────────────────────
# Resend SMTP (recommended): smtp.resend.com:587
# SendGrid: smtp.sendgrid.net:587
# Postmark: smtp.postmarkapp.com:587
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-resend-api-key

# From address shown in emails
EMAIL_FROM=TariffShield <intelligence@tariffshield.ai>
